#!/bin/sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "Running Bearer scan before push..."

if ! command -v bearer >/dev/null 2>&1; then
  echo "Error: Bearer CLI not found in PATH"
  echo "Install Bearer and retry push."
  exit 1
fi

bearer scan . --severity high,critical --scanner secrets,sast
